# ─────────────────────────────────────────────────────────────
#  WordsFilter — 환경변수 목록 (문서용 템플릿)
#
#  ⚠️ 실제 비밀 값은 여기 넣지 않는다. git 에 커밋되는 건 이 .example 뿐.
#  비밀 단일 소스 = AWS SSM Parameter Store (SecureString).
#  각 기계는 `aws sso login` 으로 임시 자격증명을 받아 런타임에 당겨온다.
#  → 로컬 .env 에는 아래 '비밀 아님' 항목만 두는 게 원칙.
#
#  (AWS Identity Center 세팅 전 브리지 단계에서만, 임시로 아래
#   CLOVA/ANTHROPIC 키를 로컬 .env 에 직접 채워 쓴다. 세팅되면 SSM 으로 이관.)
# ─────────────────────────────────────────────────────────────

# ── AWS (비밀 아님: 리전/프로필만. 자격증명은 SSO 세션) ──
AWS_REGION=ap-northeast-2
AWS_PROFILE=wordsfilter-dev

# ── STT: Naver CLOVA Speech (실서비스는 SSM /wordsfilter/dev/clova/*) ──
CLOVA_SPEECH_INVOKE_URL=
CLOVA_SPEECH_SECRET=

# ── LLM: Anthropic Claude (실서비스는 SSM /wordsfilter/dev/anthropic/*) ──
ANTHROPIC_API_KEY=

# ── DB: PostgreSQL (로컬 개발용. 실서비스는 Secrets Manager) ──
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/wordsfilter
# SPRING_DATASOURCE_USERNAME=wordsfilter
# SPRING_DATASOURCE_PASSWORD=
