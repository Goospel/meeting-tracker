# ─────────────────────────────────────────────
#  Secrets / 환경 (절대 커밋 금지)
# ─────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
application-local.yml
application-local.yaml
application-*.local.yml
secrets*.json
.aws/

# 한글 커밋 메시지 임시파일 (T-026)
.commit-msg-tmp

# ─────────────────────────────────────────────
#  Java / Spring (Gradle · Maven)
# ─────────────────────────────────────────────
build/
.gradle/
!gradle/wrapper/gradle-wrapper.jar
target/
*.class
bin/
out/
*.log
logs/
hs_err_pid*

# ─────────────────────────────────────────────
#  Node / React (Vite)
# ─────────────────────────────────────────────
node_modules/
dist/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
coverage/

# ─────────────────────────────────────────────
#  Python (benchmarks/stt — STT 벤치마크 검증 하네스)
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
# 실제 오디오·raw STT 응답은 라이선스·용량·비밀 때문에 커밋 금지 (주석 JSON만 커밋)
benchmarks/stt/fixtures/audio/
benchmarks/stt/fixtures/raw/
# TTS 매니페스트는 스크립트에서 재생성되는 파생물 — 커밋 금지 (--manifest-out으로 생성)
benchmarks/stt/fixtures/synth/*.manifest.json

# ─────────────────────────────────────────────
#  Terraform (IaC)  — .terraform.lock.hcl 은 커밋함
# ─────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
crash.log
*.tfvars
!*.tfvars.example

# ─────────────────────────────────────────────
#  IDE / OS
# ─────────────────────────────────────────────
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db
desktop.ini
